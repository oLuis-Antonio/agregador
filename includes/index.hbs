<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <title>{{siteTitle}}</title>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="alternate" type="application/rss+xml" href="{{feedHref}}" />
  <link href="index.css" rel="stylesheet" />
  <link rel="icon" type="image/svg+xml" href="antagonismo.svg">
</head>

<body>
  <header>
    <h1>{{siteTitle}}</h1>
    <p>Notícias de: O Futuro; A Verdade; Opinião Socialista; Esquerda Diário; The Intercept Brasil; Ponte Jornalismo; De Olho Nos Ruralistas; A Nova Democracia; </p>
  </header>

  <main>
    {{#each dates}}
    <section class="day">

      <h2 class="daily-heading">
        <span
          class="daily-heading-toggle__date"
          data-date="{{isoPublishDate}}">
          {{isoPublishDate}}
        </span>
      </h2>

      {{#each articles}}
      <article class="card">
        <a href="{{link}}" class="card-link" target="_blank">

          <div class="card__section">

            <h3>{{title}}</h3>

            <div class="meta">
              <span class="source">{{source.title}}</span>

              <time
                class="article-date"
                datetime="{{../isoPublishDate}}">
                {{../isoPublishDate}}
              </time>
            </div>

            <p class="description">{{description}}</p>

          </div>
        </a>
      </article>
      {{/each}}

    </section>
    {{/each}}
  </main>

  <footer>
    <span>{{siteTitle}}</span>
    <a href="{{feedHref}}" class="footer-link">RSS</a>
  </footer>

  <script src="index.js"></script>
</body>
</html>